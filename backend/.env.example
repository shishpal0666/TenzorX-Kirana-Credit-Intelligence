# TenzorX Backend Environment Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Set to "true" for demo mode (pre-crafted responses, no API calls)
# Set to "false" for live mode (real Gemini AI analysis)
DEMO_MODE=false

# CLIP fraud detection (requires torch — disable for lightweight deployment)
USE_CLIP=false

# Server port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
