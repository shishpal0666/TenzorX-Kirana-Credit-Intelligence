# ============================================================
# TenzorX Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- REQUIRED ---
# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- DEMO MODE (Set true before pitching) ---
# When true: returns pre-crafted JSON instantly. No API calls made.
# When false: runs real Gemini + XGBoost pipeline (requires model files)
DEMO_MODE=true

# --- CLIP Fraud Detection ---
# When true: downloads ~400MB CLIP model on first run for fraud checks
# Set false for demo to avoid slow startup
USE_CLIP=false

# --- Server ---
PORT=5000

# --- CORS ---
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000
